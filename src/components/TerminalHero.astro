---
import { SITE } from '../consts';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="term" role="img" aria-label="Terminal window">
    <div class="term__bar">
      <span class="dot dot--r"></span>
      <span class="dot dot--y"></span>
      <span class="dot dot--g"></span>
      <span class="term__title">doron@yay.dev: ~</span>
    </div>
    <div class="term__body">
      <p class="line"><span class="prompt"></span>whoami</p>
      <h1 id="hero-title" class="line out">{SITE.author}</h1>
      <p class="line out role">{SITE.role}</p>
      <p class="line"><span class="prompt"></span>cat about.txt</p>
      <p class="line out blurb">
        I build the infrastructure other teams rely on: large scale search,
        data pipelines, event driven systems and the infrastructure as code
        underneath them. 15 years, end to end: architecture, the hard
        performance core, and the operations to run it.
      </p>
      <p class="line">
        <span class="prompt"></span><span class="typed">open contact</span><span
          class="caret"
          aria-hidden="true">█</span
        >
      </p>
    </div>
  </div>

  <div class="hero__cta">
    <a class="btn" href="/contact">Work with me</a>
    <a class="btn btn--ghost" href="/resume">Read the résumé</a>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--sp-16) var(--sp-8);
  }
  .term {
    border: 1px solid var(--border-bright);
    border-radius: var(--radius);
    background: var(--bg-soft);
    box-shadow: 0 24px 60px -30px rgba(0, 0, 0, 0.8),
      0 0 0 1px rgba(90, 247, 142, 0.03);
    overflow: hidden;
  }
  .term__bar {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-4);
    background: #0c100e;
    border-bottom: 1px solid var(--border);
  }
  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot--r {
    background: #ff5f56;
  }
  .dot--y {
    background: #ffbd2e;
  }
  .dot--g {
    background: #27c93f;
  }
  .term__title {
    margin-left: var(--sp-3);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-dim);
  }
  .term__body {
    padding: var(--sp-6);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
  }
  .line {
    margin: 0 0 var(--sp-2);
    color: var(--text-dim);
  }
  .out {
    color: var(--text);
    margin-bottom: var(--sp-4);
  }
  h1.out {
    font-size: var(--fs-3xl);
    color: var(--text-bright);
    margin-top: var(--sp-1);
  }
  .role {
    color: var(--accent);
    font-size: var(--fs-lg);
  }
  .blurb {
    color: var(--text);
    max-width: 62ch;
    line-height: 1.7;
  }
  .typed {
    color: var(--text-bright);
  }
  .caret {
    color: var(--accent);
    animation: blink 1.1s steps(1) infinite;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
  .hero__cta {
    display: flex;
    gap: var(--sp-4);
    margin-top: var(--sp-8);
    flex-wrap: wrap;
  }
</style>
