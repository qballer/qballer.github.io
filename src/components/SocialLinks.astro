};
---

<ul class:list={['socials', className]}>
  {
    SOCIALS.map((s) => (
      <li>
        <a href={s.href} target="_blank" rel="me noopener noreferrer" aria-label={s.label}>
          <svg
            viewBox="0 0 24 24"
            width="20"
            height="20"
            fill="currentColor"
            aria-hidden="true"
            set:html={icons[s.label]}
          />
          <span class="visually-hidden">{s.label}</span>
        </a>
      </li>
    ))
  }
</ul>

<style>
  .socials {
    display: flex;
    gap: var(--sp-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .socials a {
    display: inline-flex;
    color: var(--text-dim);
    border: none;
    transition: color 0.15s var(--ease), transform 0.15s var(--ease);
  }
  .socials a:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }
</style>
