---
// Netlify Forms: static HTML form detected at deploy time.
// - name="contact" + hidden "form-name" so submissions are attributed.
// - data-netlify-honeypot + hidden "bot-field" silently drops bots.
// - action redirects to the thank-you page on success.
---

<form
  name="contact"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  action="/contact/success/"
  class="form"
>
  <input type="hidden" name="form-name" value="contact" />
  <!-- honeypot: hidden from humans, bots fill it -->
  <p class="hp">
    <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
  </p>

  <div class="field">
    <label for="name"><span class="prompt"></span>name</label>
    <input id="name" name="name" type="text" autocomplete="name" required />
  </div>

  <div class="field">
    <label for="email"><span class="prompt"></span>email</label>
    <input id="email" name="email" type="email" autocomplete="email" required />
  </div>

  <div class="field">
    <label for="message"><span class="prompt"></span>message</label>
    <textarea id="message" name="message" rows="6" required></textarea>
  </div>

  <button type="submit" class="btn">Send message</button>
</form>

<style>
  .form {
    max-width: var(--maxw-prose);
    margin-top: var(--sp-6);
  }
  .hp {
    position: absolute;
    left: -5000px;
  }
  .field {
    margin-bottom: var(--sp-4);
  }
  label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--text-dim);
    margin-bottom: var(--sp-2);
  }
  input,
  textarea {
    width: 100%;
    font-family: var(--font-mono);
    font-size: var(--fs-base);
    color: var(--text-bright);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: var(--sp-3);
    transition: border-color 0.15s var(--ease), box-shadow 0.15s var(--ease);
  }
  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--accent-dim);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }
  textarea {
    resize: vertical;
  }
  .btn {
    margin-top: var(--sp-2);
  }
</style>
