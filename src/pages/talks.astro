---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TALKS } from '../consts';
---

<BaseLayout
  title="Talks"
  description="Conference talks by Doron Tsur, including NodeTLV: TestContainers and 'Are we Deno yet?'."
>
  <div class="wrap prose">
    <p class="eyebrow">// talks</p>
    <h1>Talks</h1>
    <p class="lede">Conference talks and meetups. Mostly Node, testing and runtimes.</p>

    <ul class="talks">
      {
        TALKS.map((t) => (
          <li class="talk">
            <a class="thumb" href={t.links[0].href} target="_blank" rel="noopener noreferrer" aria-label={`Watch: ${t.title}`}>
              <img src={t.thumb} alt={`${t.title}, ${t.event} ${t.year}`} loading="lazy" width="1280" height="720" />
              <span class="play" aria-hidden="true">▶</span>
            </a>
            <div class="meta">
              <p class="venue">{t.event} · {t.year}</p>
              <h2>{t.title}</h2>
              <p class="links">
                {t.links.map((l) => (
                  <a href={l.href} target="_blank" rel="noopener noreferrer">{l.label}</a>
                ))}
              </p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>

<style>
  .lede {
    color: var(--text-dim);
  }
  .talks {
    list-style: none;
    margin: var(--sp-8) 0 0;
    padding: 0;
    display: grid;
    gap: var(--sp-8);
  }
  .talk {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: var(--sp-6);
    align-items: start;
  }
  .thumb {
    position: relative;
    display: block;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--bg-soft);
  }
  .thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.25s var(--ease), opacity 0.2s var(--ease);
  }
  .thumb:hover img {
    transform: scale(1.04);
    opacity: 0.9;
  }
  .play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 2.4rem;
    color: var(--text-bright);
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.7);
    transition: color 0.15s var(--ease), transform 0.15s var(--ease);
  }
  .thumb:hover .play {
    color: var(--accent);
    transform: scale(1.1);
  }
  .meta h2 {
    margin: var(--sp-1) 0 var(--sp-3);
    font-size: var(--fs-xl);
  }
  .venue {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--accent-dim);
    margin: 0;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
  }
  @media (max-width: 620px) {
    .talk {
      grid-template-columns: 1fr;
      gap: var(--sp-3);
    }
  }
</style>
